{
  "name": "orbisvoice",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspace=apps/api -- --quiet && npm run lint --workspace=apps/web -- --quiet && npm run lint --workspace=apps/voice-gateway -- --quiet",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "echo \"No tests configured yet.\""
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.5.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0"
  }
}
