# Build Stage
FROM node:20-slim AS builder

WORKDIR /app

# Install necessary build tools and OpenSSL for Prisma
RUN apt-get update && apt-get install -y openssl libssl-dev python3 make g++ && rm -rf /var/lib/apt/lists/*

# Copy root package files
COPY package*.json ./
COPY tsconfig.base.json ./

# Copy all workspace package.json files
COPY apps/web/package.json ./apps/web/
COPY apps/api/package.json ./apps/api/
COPY apps/voice-gateway/package.json ./apps/voice-gateway/
COPY apps/referrals/package.json ./apps/referrals/
COPY apps/commerce-agent/package.json ./apps/commerce-agent/
COPY packages/shared/package.json ./packages/shared/
COPY packages/config/package.json ./packages/config/

# Install dependencies from root
RUN npm install --legacy-peer-deps

# Copy source code
COPY apps/commerce-agent ./apps/commerce-agent
COPY packages ./packages

# Generate Prisma client and build the app
WORKDIR /app/apps/commerce-agent
RUN npx prisma generate && npm run build

# Production Stage
FROM node:20-slim AS runner

WORKDIR /app

# Install OpenSSL for Prisma runtime and curl for healthchecks
RUN apt-get update && apt-get install -y openssl libssl-dev curl && rm -rf /var/lib/apt/lists/*

ENV NODE_ENV=production

# Copy mandatory package files for the workspace and shared packages
COPY package*.json ./
COPY apps/commerce-agent/package*.json ./apps/commerce-agent/
COPY packages ./packages

# Install ONLY production dependencies for the commerce-agent workspace
RUN npm install --omit=dev --workspace=apps/commerce-agent --legacy-peer-deps

# Copy built assets and necessary runtime files from builder
COPY --from=builder /app/apps/commerce-agent/dist ./apps/commerce-agent/dist
COPY --from=builder /app/apps/commerce-agent/prisma ./apps/commerce-agent/prisma
COPY --from=builder /app/apps/commerce-agent/src/generated ./apps/commerce-agent/src/generated

# Expose Commerce Agent port
EXPOSE 4005

# Set the working directory to the app
WORKDIR /app/apps/commerce-agent

# Start the server
CMD ["node", "dist/index.js"]
